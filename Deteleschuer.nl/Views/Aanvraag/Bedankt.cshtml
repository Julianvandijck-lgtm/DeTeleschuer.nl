@{
    ViewData["Title"] = "De Teleschuer — Aanvraag ontvangen";
}

@section Styles {
    <style>
        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: var(--space-4);
        }

        .kaart {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius);
            padding: var(--space-5) var(--space-4);
            max-width: 480px;
            text-align: center;
        }

        h1 {
            margin: 0 0 var(--space-3);
            font-size: clamp(1.75rem, 3.5vw, 2.5rem);
            font-weight: 600;
            letter-spacing: -0.03em;
        }

        p {
            margin: 0;
            color: var(--color-muted);
            line-height: 1.6;
        }
    </style>
}

<main class="kaart">
    <h1>Aanvraag ontvangen</h1>
    <p>Bedankt voor uw aanvraag. Roland neemt zo spoedig mogelijk contact met u op om uw persoonlijke contract verder af te handelen.</p>
</main>
