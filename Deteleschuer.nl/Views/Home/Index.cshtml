@model List<AbonnementDto>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>De Teleschuer — Kies uw abonnement</title>
    <link rel="stylesheet" href="https://geistfont.vercel.app/geist.css" />
    <style>
        :root {
            --color-bg: #fafafa;
            --color-surface: #ffffff;
            --color-text: #111111;
            --color-muted: #666666;
            --color-border: #e5e5e5;
            --color-accent: #000000;
            --space-2: 1rem;
            --space-3: 1.5rem;
            --space-4: 2rem;
            --space-5: 3rem;
            --radius: 12px;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Geist', sans-serif;
            color: var(--color-text);
            background: var(--color-bg);
            line-height: 1.5;
        }

        header {
            padding: var(--space-5) var(--space-4) var(--space-3);
        }

        header h1 {
            margin: 0;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 600;
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        main {
            padding: 0 var(--space-4) var(--space-5);
            container-type: inline-size;
            container-name: catalog;
        }

        .filter {
            display: flex;
            gap: var(--space-2);
            align-items: center;
            margin-bottom: var(--space-4);
        }

        .filter select,
        .filter button {
            font-family: inherit;
            font-size: 1rem;
            padding: 0.5rem var(--space-2);
            border-radius: var(--radius);
        }

        .filter select {
            border: 1px solid var(--color-border);
            background: var(--color-surface);
        }

        .filter button {
            background: var(--color-accent);
            color: var(--color-surface);
            border: none;
            cursor: pointer;
        }

        .cards {
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--space-3);
        }

        @@container catalog (min-width: 600px) {
            .cards { grid-template-columns: repeat(2, 1fr); }
        }

        @@container catalog (min-width: 960px) {
            .cards { grid-template-columns: repeat(3, 1fr); }
        }

        .card {
            display: flex;
            flex-direction: column;
            gap: var(--space-2);
            padding: var(--space-3);
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius);
        }

        .card-provider {
            font-size: 0.8rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--color-muted);
        }

        .card-name {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
        }

        .card-price {
            font-size: 2rem;
            font-weight: 500;
            letter-spacing: -0.02em;
        }

        .card-description {
            color: var(--color-muted);
            flex: 1;
        }

        .card-button {
            margin-top: auto;
            padding: 0.75rem var(--space-2);
            background: var(--color-accent);
            color: var(--color-surface);
            border-radius: var(--radius);
            text-align: center;
            text-decoration: none;
            font-weight: 500;
            
        }

        .empty {
            color: var(--color-muted);
        }
    </style>
</head>
<body>
    <header>
        <h2>DeTeleschuer.nl</h2>
        <h1>Kies uw abonnement !</h1>
    </header>

    <main>
        <form class="filter" method="get">
            <label for="provider-select">Provider:</label>
            <select id="provider-select" name="provider">
                <option value="">Alle</option>
                <option value="Odido">Odido</option>
                <option value="Vodafone">Vodafone</option>
            </select>
            <button type="submit">Toepassen</button>
        </form>

        @if (Model.Count == 0)
        {
            <p class="empty">Er zijn op dit moment geen actieve abonnementen beschikbaar.</p>
        }
        else
        {
            <div class="cards">
                @foreach (var abonnement in Model)
                {
                    <article class="card">
                        <span class="card-provider">@abonnement.Provider</span>
                        <h2 class="card-name">@abonnement.Naam</h2>
                        <div class="card-price">€ @abonnement.PrijsPerMaand.ToString("0.00") /maand</div>
                        <p class="card-description">@abonnement.Beschrijving</p>
                        <a class="card-button" href="/aanvraag/starten?abonnementId=@abonnement.Id">Kies dit abonnement</a>
                    </article>
                }
            </div>
        }
    </main>
</body>
</html>