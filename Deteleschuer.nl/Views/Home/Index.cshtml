@model List<AbonnementDto>
@{// ❯ het zorgt ervoor dat de juiste list die in controller word gereturned en word gebruikt voor deze view en voila hij heeft alle juiste gegevens die op de pagina moeten getoond worden.
    ViewData["Title"] = "De Teleschuer — Kies uw abonnement";
}

@section Styles {
    <link rel="stylesheet" href="~/css/fonts.css" />
    <link rel="stylesheet" href="~/css/index.css" />
}

<header class="site-header">
    <div class="site-header__inner">
        <a class="brand" href="/">
            <img src="~/img/logo-dt.png" alt="DeTeleschuer.nl" />
        </a>
    </div>
</header>

<div class="page">

    <header class="hero">
        <h1>Kies het abonnement dat bij u past</h1>
        <p>Bekijk hieronder alle beschikbare abonnementen van Vodafone en Odido. Wilt u meer weten over een abonnement of de werkwijze? Neem dan eerst contact op met Roland, hij helpt u graag verder.</p>
    </header>

    <div class="filter-row">
        <form class="filter" method="get">
        <label for="provider-select">Provider</label>
        <span class="filter__select">
            <select id="provider-select" name="provider">
                <option value="">Alle providers</option>
                <option value="Odido">Odido</option>
                <option value="Vodafone">Vodafone</option>
            </select>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </span>
            <button type="submit">Toepassen</button>
        </form>
    </div>

    @if (Model.Count == 0) // als de lijst leeg is toon een melding anders de kaarten
    {
        <p class="empty">Er zijn op dit moment geen actieve abonnementen beschikbaar.</p>
    }
    else
    {
        <div class="cards">
            @foreach (var abonnement in Model) //loop door elk abonnement en maak een kaart aan
            {
                var naamDelen = abonnement.Naam.Split(new[] { ' ' }, 2); //naam splitsen op eerste spatie zodat eerste woord apart gestijld kan worden
                var voorwoord = naamDelen[0];
                var hoofdwoord = naamDelen.Length > 1 ? naamDelen[1] : "";
                var providerClass = abonnement.Provider == "Vodafone" ? "card--vodafone" : "card--odido"; //juiste css klasse op basis van provider

                <article class="card @providerClass">
                    <div class="card__head">
                        <h2 class="card__title">
                            <span class="pre">@voorwoord</span>
                            @if (!string.IsNullOrEmpty(hoofdwoord))
                            {
                                <span class="main">@hoofdwoord</span>
                            }
                        </h2>
                        <span class="card__logo">
                            @if (abonnement.Provider == "Vodafone")
                            {
                                <img src="~/img/vodafone.png" alt="Vodafone" />
                            }
                            else if (abonnement.Provider == "Odido")
                            {
                                <img src="~/img/odido.webp" alt="Odido" />
                            }
                        </span>
                    </div>

                    <p class="card__desc">@abonnement.Beschrijving</p>

                    <div class="card__divider"></div>

                    <div class="card__foot">
                        <span class="card__price">
                            <span class="amount">&euro;@abonnement.PrijsPerMaand.ToString("0.00")</span> @* altijd 2 decimalen tonen *@
                            <span class="per">/maand</span>
                        </span>
                        <a class="card__btn" href="/aanvraag/starten?abonnementId=@abonnement.Id">Kies</a> @* id meesturen zodat de aanvraag weet welk abonnement gekozen is *@
                    </div>
                </article>
            }
        </div>
    }

</div>
