@model AbonnementOverzichtViewModel
@{
    ViewData["Title"] = "De Teleschuer — Kies uw abonnement";
}

@section Styles {
    <link rel="stylesheet" href="~/css/fonts.css" />
    <link rel="stylesheet" href="~/css/index.css" />
}

<header class="site-header">
    <div class="site-header__inner">
        <a class="brand" href="/">
            <img src="~/img/logo-dt.png" alt="DeTeleschuer.nl" />
        </a>
    </div>
</header>

<div class="page">

    <header class="hero">
        <h1>Kies het abonnement dat bij u past</h1>
        <p>Bekijk hieronder alle beschikbare abonnementen van Vodafone en Odido. Wilt u meer weten over een abonnement of de werkwijze? Neem dan eerst contact op met Roland, hij helpt u graag verder.</p>
    </header>

    <div class="filter-row">
        <form class="filter" method="get">
            <label for="provider-select">Provider</label>
            <span class="filter__select">
                <select id="provider-select" name="provider">
                    <option value="" selected="@(Model.GekozenProvider == null)">Alle providers</option>
                    <option value="Odido" selected="@(Model.GekozenProvider == "Odido")">Odido</option>
                    <option value="Vodafone" selected="@(Model.GekozenProvider == "Vodafone")">Vodafone</option>
                </select>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </span>
            <button type="submit">Toepassen</button>
        </form>
    </div>

    @if (Model.Abonnementen.Count == 0)
    {
        <p class="empty">Er zijn op dit moment geen actieve abonnementen beschikbaar.</p>
    }
    else
    {
        <div class="cards">
            @foreach (var abonnement in Model.Abonnementen)
            {
                var naamDelen = abonnement.Naam.Split(new[] { ' ' }, 2);
                var voorwoord = naamDelen[0];
                var hoofdwoord = naamDelen.Length > 1 ? naamDelen[1] : "";

                <article class="card @abonnement.ProviderCssKlasse">
                    <div class="card__head">
                        <h2 class="card__title">
                            <span class="pre">@voorwoord</span>
                            @if (!string.IsNullOrEmpty(hoofdwoord))
                            {
                                <span class="main">@hoofdwoord</span>
                            }
                        </h2>
                        <span class="card__logo">
                            <img src="@abonnement.ProviderLogoSrc" alt="@abonnement.ProviderTekst" />
                        </span>
                    </div>

                    <p class="card__desc">@abonnement.Beschrijving</p>

                    <div class="card__divider"></div>

                    <div class="card__foot">
                        <span class="card__price">
                            <span class="amount">&euro;@abonnement.PrijsPerMaand.ToString("0.00")</span>
                            <span class="per">/maand</span>
                        </span>
                        <a class="card__btn" href="/aanvraag/starten?abonnementId=@abonnement.Id">Kies</a>
                    </div>
                </article>
            }
        </div>
    }

</div>
