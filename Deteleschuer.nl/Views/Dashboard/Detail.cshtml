@using Interface.Dtos
@model AanvraagDetailDto
@{
    ViewData["Title"] = "De Teleschuer — Aanvraag";
}

@section Styles {
    <style>
        header { padding: var(--space-4); display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--color-border); }
        header h1 { margin: 0; font-size: 1.5rem; font-weight: 600; }
        .terug { color: var(--color-muted); text-decoration: none; font-size: 0.9rem; }
        main { padding: var(--space-4); max-width: 800px; }
        .sectie { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-3); margin-bottom: var(--space-3); }
        .sectie h2 { margin: 0 0 var(--space-2); font-size: 1rem; font-weight: 600; }
        .rij { display: flex; gap: var(--space-2); margin-bottom: 0.5rem; font-size: 0.95rem; }
        .label { color: var(--color-muted); min-width: 160px; }
        .fotos { display: flex; gap: var(--space-2); margin-top: var(--space-2); }
        .fotos img { width: 200px; border-radius: var(--radius); border: 1px solid var(--color-border); }
        .handtekening img { max-width: 300px; border: 1px solid var(--color-border); border-radius: var(--radius); }
        select { font-family: inherit; font-size: 0.95rem; padding: 0.4rem 0.8rem; border: 1px solid var(--color-border); border-radius: var(--radius); }
        .knop { padding: 0.5rem var(--space-2); background: var(--color-accent); color: white; border: none; border-radius: var(--radius); font-family: inherit; font-size: 0.9rem; cursor: pointer; }
        textarea { width: 100%; font-family: inherit; font-size: 0.95rem; padding: 0.65rem var(--space-2); border: 1px solid var(--color-border); border-radius: var(--radius); resize: vertical; min-height: 80px; margin-bottom: var(--space-2); }
        .notitie-item { border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-2); margin-bottom: var(--space-2); }
        .notitie-datum { font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.4rem; }
    </style>
}

<header>
    <h1>Aanvraag — @Model.KlantNaam</h1>
    <a asp-controller="Dashboard" asp-action="Index" class="terug">← Terug naar overzicht</a>
</header>

<main>
    <div class="sectie">
        <h2>Persoonsgegevens</h2>
        <div class="rij"><span class="label">Naam</span><span>@Model.KlantNaam</span></div>
        <div class="rij"><span class="label">Adres</span><span>@Model.KlantAdres</span></div>
        <div class="rij"><span class="label">Geboortedatum</span><span>@Model.KlantGeboortedatum.ToString("dd-MM-yyyy")</span></div>
        <div class="rij"><span class="label">E-mail</span><span>@Model.KlantEmail</span></div>
        <div class="rij"><span class="label">Telefoon</span><span>@Model.KlantTelefoon</span></div>
        <div class="rij"><span class="label">Abonnement</span><span>@Model.AbonnementNaam</span></div>
        <div class="rij"><span class="label">Nummerbehoud</span><span>@(Model.NummerBehouden == true ? "Ja" : "Nee")</span></div>
        <div class="rij"><span class="label">Aanvraagdatum</span><span>@Model.AanvraagDatum.ToString("dd-MM-yyyy")</span></div>
    </div>

    <div class="sectie">
        <h2>Documenten</h2>
        <div class="fotos">
            <div>
                <div class="label" style="margin-bottom:0.4rem;">Legitimatiebewijs</div>
                <img src="/uploads/@Model.FotoLegitimatie" alt="Legitimatie" />
            </div>
            <div>
                <div class="label" style="margin-bottom:0.4rem;">Bankpas</div>
                <img src="/uploads/@Model.FotoBankpas" alt="Bankpas" />
            </div>
        </div>
    </div>

    <div class="sectie handtekening">
        <h2>Digitale handtekening</h2>
        <img src="@Model.DigitaleHandtekening" alt="Handtekening" />
    </div>

    <div class="sectie">
        <form method="post" asp-controller="Dashboard" asp-action="StatusBijwerken">
            <input type="hidden" name="id" value="@Model.Id" />
            <select name="status">
                @foreach (var s in new[] { "Nieuw", "In behandeling", "Afgerond" })
                {
                    if (s == Model.Status)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
            <button class="knop" type="submit">Opslaan</button>
        </form>
    </div>

    <div class="sectie">
        <h2>Notities</h2>

        @foreach (var notitie in Model.Notities)
        {
            <div class="notitie-item">
                <div class="notitie-datum">@notitie.DatumAangemaakt.ToString("dd-MM-yyyy HH:mm")</div>
                <form method="post" asp-controller="Dashboard" asp-action="NotitieBijwerken">
                    <input type="hidden" name="id" value="@notitie.Id" />
                    <input type="hidden" name="aanvraagId" value="@Model.Id" />
                    <textarea name="tekst">@notitie.Tekst</textarea>
                    <button class="knop" type="submit">Opslaan</button>
                </form>
            </div>
        }

        <form method="post" asp-controller="Dashboard" asp-action="NotitieOpslaan" style="margin-top:var(--space-2);">
            <input type="hidden" name="aanvraagId" value="@Model.Id" />
            <textarea name="tekst" placeholder="Nieuwe notitie..."></textarea>
            <button class="knop" type="submit">Notitie toevoegen</button>
        </form>
    </div>
</main>
